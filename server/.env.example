# 复制本文件为 .env 后填写真实值。.env 已被 .gitignore 忽略，切勿提交到仓库。

# Dify 云端地址（官方云端保持默认即可；私有部署改成你的实例地址，需带 /v1）
DIFY_BASE_URL=https://api.dify.ai/v1

# Dify 应用的 Service API Key（Dify 后台「访问 API」页面获取，形如 app-xxxxxxxx）
# 留空时后端自动进入 MOCK 模式，用假数据跑通链路，方便无 Key 情况下调试前端。
DIFY_API_KEY=

# 服务监听端口
PORT=3000

# 是否强制开启 mock 模式（true/false）。
# 不设置时：有 Key 走真实 Dify，无 Key 自动 mock。
MOCK=

# 允许跨域的来源，多个用英文逗号分隔。留空表示允许全部（开发期方便，正式部署建议收紧）。
# WKWebView 加载本地文件时 origin 为 null，已内置允许，无需在此填写。
CORS_ORIGINS=
